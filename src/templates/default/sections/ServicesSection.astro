---
import type { ServicesContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: ServicesContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, subtitle, items } = content;
const { theme } = tenant;
---

<section class="py-24 bg-white">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-4xl font-extrabold text-gray-900 md:text-5xl">{heading}</h2>
      {subtitle && <p class="mx-auto max-w-2xl text-lg text-gray-500">{subtitle}</p>}
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg">
          <div
            class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl text-2xl shadow-sm"
            style={`background: ${theme.primaryColor}15;`}
          >
            {item.icon ?? "⚡"}
          </div>
          <h3 class="mb-3 text-xl font-bold text-gray-900">{item.title}</h3>
          <p class="leading-relaxed text-gray-500">{item.description}</p>
          <div class="mt-4 h-1 w-10 rounded-full" style={`background: ${theme.accentColor};`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
