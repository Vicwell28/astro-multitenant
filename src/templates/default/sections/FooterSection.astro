---
import type { FooterContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: FooterContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { text, columns, socialLinks } = content;
const { theme } = tenant;
---

<footer style={`background: #0f172a;`} class="text-slate-400">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="mb-4 flex items-center gap-3">
      <div class="h-8 w-8 rounded-lg" style={`background: ${theme.primaryColor};`}></div>
      <span class="text-lg font-bold text-white">{tenant.name}</span>
    </div>
    {columns && columns.length > 0 && (
      <div class="mb-12 grid gap-8 border-t border-slate-800 pt-10 sm:grid-cols-2 lg:grid-cols-4">
        {columns.map((col) => (
          <div>
            <h4 class="mb-4 text-xs font-bold uppercase tracking-widest text-slate-300">{col.title}</h4>
            <ul class="space-y-2">
              {col.links.map((link) => (
                <li>
                  <a href={link.url} class="text-sm hover:text-white transition-colors">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}
    <div class="flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-8 md:flex-row">
      <p class="text-sm">{text}</p>
      {socialLinks && socialLinks.length > 0 && (
        <div class="flex gap-5">
          {socialLinks.map((s) => (
            <a href={s.url} class="text-sm font-medium hover:text-white transition-colors">{s.platform}</a>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>
