---
import type { FooterContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: FooterContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { text, columns, socialLinks } = content;
const { theme } = tenant;
---

<footer style={`background: ${theme.primaryColor};`} class="text-blue-200">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <!-- Gold accent top border -->
    <div class="mb-12 flex items-center gap-4">
      <span class="text-xl font-bold text-white" style="font-family: var(--font-heading, 'Playfair Display', serif);">{tenant.name}</span>
      <div class="ml-4 h-px flex-1" style={`background: ${theme.accentColor};`}></div>
    </div>

    {columns && columns.length > 0 && (
      <div class="mb-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {columns.map((col) => (
          <div>
            <h4 class="mb-5 text-xs font-bold uppercase tracking-widest" style={`color: ${theme.accentColor};`}>{col.title}</h4>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.url} class="text-sm text-blue-200 transition-colors hover:text-white">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}

    <!-- Gold divider -->
    <div class="mb-8 h-px" style={`background: ${theme.accentColor}50;`}></div>

    <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
      <p class="text-sm text-blue-300">{text}</p>
      {socialLinks && socialLinks.length > 0 && (
        <div class="flex gap-6">
          {socialLinks.map((s) => (
            <a href={s.url} class="text-sm font-medium transition-colors hover:text-white" style={`color: ${theme.accentColor};`}>{s.platform}</a>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>
