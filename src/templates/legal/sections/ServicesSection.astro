---
import type { ServicesContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: ServicesContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, subtitle, items } = content;
const { theme } = tenant;
---

<section class="py-24 bg-gray-50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <div class="mx-auto mb-4 flex items-center justify-center gap-4">
        <div class="h-px w-12" style={`background: ${theme.accentColor};`}></div>
        <span class="text-sm font-bold uppercase tracking-widest" style={`color: ${theme.accentColor};`}>Áreas de Práctica</span>
        <div class="h-px w-12" style={`background: ${theme.accentColor};`}></div>
      </div>
      <h2 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl" style="font-family: var(--font-heading, 'Playfair Display', serif);">{heading}</h2>
      {subtitle && <p class="mx-auto max-w-2xl text-lg text-gray-600">{subtitle}</p>}
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="group rounded-sm border border-gray-200 bg-white p-8 transition-all hover:shadow-md" style={`border-top: 3px solid ${theme.accentColor};`}>
          {item.icon && <div class="mb-4 text-3xl">{item.icon}</div>}
          <h3 class="mb-3 text-lg font-bold text-gray-900" style="font-family: var(--font-heading, 'Playfair Display', serif);">{item.title}</h3>
          <p class="text-sm leading-relaxed text-gray-600">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
