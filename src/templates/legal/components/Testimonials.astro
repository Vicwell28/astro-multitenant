---
import type { TenantConfig } from "../../../lib/types.ts";

interface Props {
  tenant: TenantConfig;
}
const { tenant } = Astro.props;
const testimonials = tenant.content.testimonials ?? [];
---

<section id="testimonios" class="py-20" style={`background-color: ${tenant.primaryColor}`}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="w-12 h-0.5 bg-yellow-400 mx-auto mb-4" />
      <h2 class="font-serif text-4xl font-bold text-white">Lo que dicen nuestros clientes</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-lg p-8">
          <p class="text-white/90 text-lg italic leading-relaxed mb-6">"{t.text}"</p>
          <div>
            <p class="text-yellow-400 font-semibold">{t.author}</p>
            {t.role && <p class="text-white/60 text-sm mt-0.5">{t.role}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
