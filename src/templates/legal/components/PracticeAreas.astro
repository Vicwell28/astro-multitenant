---
import type { TenantConfig } from "../../../lib/types.ts";

interface Props {
  tenant: TenantConfig;
}
const { tenant } = Astro.props;
const areas = tenant.content.practiceAreas ?? [];
---

<section id="areas" class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-14">
      <div class="w-12 h-0.5 bg-yellow-400 mx-auto mb-4" />
      <h2 class="font-serif text-4xl font-bold text-gray-900">Áreas de Práctica</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {areas.map((area) => (
        <div
          class="bg-white rounded-lg p-7 border-t-4 shadow-sm hover:shadow-md transition-shadow"
          style="border-top-color: #D4AF37"
        >
          {area.icon && <div class="text-3xl mb-3">{area.icon}</div>}
          <h3 class="font-serif text-lg font-bold text-gray-900 mb-2">{area.title}</h3>
          {area.description && <p class="text-gray-500 text-sm">{area.description}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
