---
import type { TenantConfig } from "../../../lib/types.ts";

interface Props {
  tenant: TenantConfig;
}
const { tenant } = Astro.props;
const hero = tenant.content.hero ?? {};
---

<section
  class="relative min-h-screen flex items-center justify-center text-white overflow-hidden"
  style={`background: linear-gradient(135deg, ${tenant.primaryColor} 0%, ${tenant.secondaryColor} 60%, #1a1a2e 100%)`}
>
  {hero.image && (
    <div
      class="absolute inset-0 bg-cover bg-center opacity-20"
      style={`background-image: url('${hero.image}')`}
    />
  )}
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/30" />
  <div class="relative z-10 max-w-4xl mx-auto text-center px-6">
    <div class="inline-block bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium mb-8">
      ✨ Experiencia Premium
    </div>
    <h1 class="text-6xl font-black mb-6 leading-tight">
      {hero.title ?? tenant.name}
    </h1>
    {hero.subtitle && (
      <p class="text-xl mb-10 opacity-85 max-w-2xl mx-auto">{hero.subtitle}</p>
    )}
    {hero.cta && (
      <a
        href="#about"
        class="inline-block px-10 py-4 bg-white font-bold rounded-xl shadow-2xl hover:scale-105 transition-transform text-lg"
        style={`color: ${tenant.primaryColor}`}
      >
        {hero.cta}
      </a>
    )}
  </div>
</section>
