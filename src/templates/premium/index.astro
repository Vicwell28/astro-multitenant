---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "./components/Header.astro";
import Hero from "./components/Hero.astro";
import Footer from "./components/Footer.astro";
import type { TenantConfig } from "../../lib/types.ts";

interface Props {
  tenant: TenantConfig;
  slug?: string[];
}

const { tenant } = Astro.props;
const about = tenant.content.about;
---

<BaseLayout tenant={tenant}>
  <Header tenant={tenant} />
  <Hero tenant={tenant} />

  {about && (
    <section id="about" class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl font-black text-gray-900 mb-6">{about.title}</h2>
        <p class="text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">{about.description}</p>
        <div
          class="mt-8 inline-block w-20 h-1 rounded-full"
          style={`background: linear-gradient(90deg, ${tenant.primaryColor}, ${tenant.secondaryColor})`}
        />
      </div>
    </section>
  )}

  <section id="servicios" class="py-24 bg-gradient-to-br from-gray-50 to-purple-50/30">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-4xl font-black text-center text-gray-900 mb-16">Nuestras Soluciones</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon: "🚀", title: "Innovación", desc: "Tecnología de vanguardia para tu empresa." },
          { icon: "🎯", title: "Estrategia", desc: "Planificación precisa orientada a resultados." },
          { icon: "💎", title: "Calidad", desc: "Estándares premium en cada entrega." },
        ].map((item) => (
          <div
            class="rounded-3xl p-8 bg-white shadow-xl border border-gray-100 hover:scale-105 transition-transform"
          >
            <div class="text-5xl mb-6">{item.icon}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer tenant={tenant} />
</BaseLayout>
