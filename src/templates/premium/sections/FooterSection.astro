---
import type { FooterContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: FooterContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { text, columns, socialLinks } = content;
const { theme } = tenant;
---

<footer class="bg-gray-950 text-gray-400">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <!-- Brand -->
    <div class="mb-10 flex items-center gap-4">
      <div class="h-10 w-10 rounded-full" style={`background: linear-gradient(135deg, ${theme.primaryColor}, ${theme.accentColor});`}></div>
      <span class="text-xl font-bold text-white" style="font-family: var(--font-heading, 'Playfair Display', serif);">{tenant.name}</span>
    </div>

    {columns && columns.length > 0 && (
      <div class="mb-12 grid gap-8 border-t border-gray-800 pt-12 sm:grid-cols-2 lg:grid-cols-4">
        {columns.map((col) => (
          <div>
            <h4 class="mb-5 text-xs font-bold uppercase tracking-widest" style={`color: ${theme.accentColor};`}>{col.title}</h4>
            <ul class="space-y-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.url} class="text-sm transition-colors hover:text-white">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}

    <div class="flex flex-col items-center justify-between gap-4 border-t border-gray-800 pt-8 md:flex-row">
      <p class="text-sm">{text}</p>
      {socialLinks && socialLinks.length > 0 && (
        <div class="flex gap-6">
          {socialLinks.map((s) => (
            <a href={s.url} class="text-sm font-medium transition-colors hover:text-white"
              style={`color: ${theme.accentColor};`}>{s.platform}</a>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>
