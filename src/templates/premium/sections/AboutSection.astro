---
import type { AboutContent, Tenant } from "../../../lib/types.ts";

interface Props {
  content: AboutContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, description, image, imagePosition = "right" } = content;
const { theme } = tenant;
---

<section class="py-28 bg-white">
  <div class="mx-auto max-w-6xl px-6">
    <div class={`flex flex-col gap-16 md:flex-row md:items-center ${imagePosition === "left" ? "md:flex-row-reverse" : ""}`}>
      <div class="flex-1">
        <div class="mb-4 h-1 w-16 rounded-full" style={`background: ${theme.accentColor};`}></div>
        <h2 class="mb-6 text-4xl font-bold text-gray-900 md:text-5xl" style="font-family: var(--font-heading, 'Playfair Display', serif);">
          {heading}
        </h2>
        <div class="space-y-5">
          {description.split("\n\n").map((para) => (
            <p class="text-lg leading-loose text-gray-600">{para}</p>
          ))}
        </div>
      </div>
      <div class="flex-1">
        {image ? (
          <img
            src={image}
            alt={heading}
            class="h-[480px] w-full rounded-3xl object-cover shadow-2xl"
          />
        ) : (
          <div
            class="flex h-[480px] w-full items-center justify-center rounded-3xl shadow-2xl"
            style={`background: linear-gradient(135deg, ${theme.primaryColor}20, ${theme.accentColor}20);`}
          >
            <span class="text-7xl">✨</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
