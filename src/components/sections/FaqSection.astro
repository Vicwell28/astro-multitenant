---
import type { FaqContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: FaqContent;
  tenant: Tenant;
}

const { content } = Astro.props;
const { heading, items } = content;
---

<section class="py-20 bg-white">
  <div class="mx-auto max-w-3xl px-6">
    <h2 class="mb-12 text-center text-4xl font-bold text-gray-900">{heading}</h2>
    <div class="space-y-6">
      {items.map((item) => (
        <div class="rounded-xl border border-gray-200 p-6">
          <h3 class="mb-3 text-lg font-bold text-gray-900">{item.question}</h3>
          <p class="leading-relaxed text-gray-600">{item.answer}</p>
        </div>
      ))}
    </div>
  </div>
</section>
