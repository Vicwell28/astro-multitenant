---
import type { CtaBannerContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: CtaBannerContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, description, ctaText, ctaUrl, backgroundColor } = content;
const bg = backgroundColor ?? tenant.theme.primaryColor;
---

<section class="py-20" style={`background: ${bg};`}>
  <div class="mx-auto max-w-4xl px-6 text-center">
    <h2 class="mb-4 text-4xl font-bold text-white">{heading}</h2>
    {description && <p class="mx-auto mb-10 max-w-2xl text-lg text-white opacity-90">{description}</p>}
    <a
      href={ctaUrl}
      class="inline-block rounded-lg bg-white px-10 py-4 text-lg font-bold transition-all hover:shadow-xl"
      style={`color: ${bg};`}
    >
      {ctaText}
    </a>
  </div>
</section>
