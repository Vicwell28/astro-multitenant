---
import type { StatsContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: StatsContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, items } = content;
const { theme } = tenant;
---

<section class="py-20" style={`background: ${theme.primaryColor};`}>
  <div class="mx-auto max-w-5xl px-6">
    {heading && (
      <h2 class="mb-12 text-center text-3xl font-bold text-white">{heading}</h2>
    )}
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {items.map((item) => (
        <div class="text-center">
          {item.icon && <div class="mb-2 text-4xl">{item.icon}</div>}
          <div class="text-4xl font-bold text-white">{item.value}</div>
          <div class="mt-2 text-sm font-medium text-white opacity-80">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
