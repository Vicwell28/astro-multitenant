---
import type { AboutContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: AboutContent;
  tenant: Tenant;
}

const { content } = Astro.props;
const { heading, description, image, imagePosition = "right" } = content;
---

<section class="py-20 bg-white">
  <div class="mx-auto max-w-6xl px-6">
    <div class={`flex flex-col gap-12 md:flex-row md:items-center ${imagePosition === "left" ? "md:flex-row-reverse" : ""}`}>
      <div class="flex-1">
        <h2 class="mb-6 text-4xl font-bold text-gray-900">{heading}</h2>
        <div class="space-y-4">
          {description.split("\n\n").map((para) => (
            <p class="text-lg leading-relaxed text-gray-600">{para}</p>
          ))}
        </div>
      </div>
      {image && (
        <div class="flex-1">
          <img
            src={image}
            alt={heading}
            class="h-80 w-full rounded-2xl object-cover shadow-lg"
          />
        </div>
      )}
      {!image && (
        <div class="flex-1">
          <div class="flex h-80 w-full items-center justify-center rounded-2xl bg-gradient-to-br from-gray-100 to-gray-200">
            <span class="text-6xl">🏢</span>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
