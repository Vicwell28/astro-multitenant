---
import type { TeamContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: TeamContent;
  tenant: Tenant;
}

const { content } = Astro.props;
const { heading, subtitle, members } = content;
---

<section class="py-20 bg-white">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <h2 class="mb-4 text-4xl font-bold text-gray-900">{heading}</h2>
      {subtitle && <p class="mx-auto max-w-2xl text-lg text-gray-600">{subtitle}</p>}
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {members.map((member) => (
        <div class="text-center">
          {member.image ? (
            <img
              src={member.image}
              alt={member.name}
              class="mx-auto mb-4 h-28 w-28 rounded-full object-cover shadow"
            />
          ) : (
            <div class="mx-auto mb-4 flex h-28 w-28 items-center justify-center rounded-full bg-gray-200 text-4xl shadow">
              👤
            </div>
          )}
          <h3 class="mb-1 text-lg font-semibold text-gray-900">{member.name}</h3>
          <p class="mb-2 text-sm font-medium text-gray-500">{member.role}</p>
          {member.bio && <p class="text-sm leading-relaxed text-gray-600">{member.bio}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
