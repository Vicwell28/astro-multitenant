---
import type { HeroContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: HeroContent;
  tenant: Tenant;
}

const { content, tenant } = Astro.props;
const { heading, subheading, ctaText, ctaUrl, ctaSecondaryText, ctaSecondaryUrl, backgroundImage, overlayOpacity = 0.5 } = content;
const { theme } = tenant;
---

<section
  class="relative flex min-h-[70vh] items-center justify-center overflow-hidden"
  style={backgroundImage ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: center;` : `background: linear-gradient(135deg, ${theme.primaryColor} 0%, ${theme.secondaryColor} 100%);`}
>
  {backgroundImage && (
    <div class="absolute inset-0" style={`background: rgba(0,0,0,${overlayOpacity});`}></div>
  )}
  <div class="relative z-10 mx-auto max-w-5xl px-6 py-24 text-center text-white">
    <h1 class="mb-6 text-5xl font-bold leading-tight tracking-tight md:text-6xl">
      {heading}
    </h1>
    {subheading && (
      <p class="mx-auto mb-10 max-w-2xl text-xl leading-relaxed opacity-90">
        {subheading}
      </p>
    )}
    <div class="flex flex-wrap justify-center gap-4">
      {ctaText && ctaUrl && (
        <a
          href={ctaUrl}
          class="rounded-lg px-8 py-4 text-lg font-semibold transition-all hover:opacity-90 hover:shadow-lg"
          style={`background: ${theme.accentColor}; color: #fff;`}
        >
          {ctaText}
        </a>
      )}
      {ctaSecondaryText && ctaSecondaryUrl && (
        <a
          href={ctaSecondaryUrl}
          class="rounded-lg border-2 border-white px-8 py-4 text-lg font-semibold text-white transition-all hover:bg-white hover:text-gray-900"
        >
          {ctaSecondaryText}
        </a>
      )}
    </div>
  </div>
</section>
