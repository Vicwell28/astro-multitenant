---
import type { TestimonialsContent, Tenant } from "../../lib/types.ts";

interface Props {
  content: TestimonialsContent;
  tenant: Tenant;
}

const { content } = Astro.props;
const { heading, items } = content;
---

<section class="py-20 bg-gray-50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-14 text-center">
      <h2 class="mb-4 text-4xl font-bold text-gray-900">{heading}</h2>
    </div>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 text-5xl leading-none text-gray-200">"</div>
          <p class="mb-6 italic leading-relaxed text-gray-700">"{item.quote}"</p>
          <div class="flex items-center gap-3">
            {item.avatar ? (
              <img src={item.avatar} alt={item.author} class="h-10 w-10 rounded-full object-cover" />
            ) : (
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gray-200 text-lg">👤</div>
            )}
            <div>
              <p class="font-semibold text-gray-900">{item.author}</p>
              {item.role && <p class="text-sm text-gray-500">{item.role}</p>}
            </div>
          </div>
          {item.rating && (
            <div class="mt-4 flex gap-1 text-yellow-400">
              {Array.from({ length: item.rating }).map(() => <span>★</span>)}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
